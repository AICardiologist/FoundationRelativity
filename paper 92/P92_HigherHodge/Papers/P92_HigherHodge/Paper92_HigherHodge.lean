    which is dominated by the Fermat curve F₂₀. -/
theorem fermat_anchor_g5 (u v : ℤ) (_h : u ^ 20 + v ^ 20 = 1) :
    True := trivial

/-- At the origin, genus 6 specializes to y² = x¹³ + x
    which is dominated by the Fermat curve F₂₄. -/
