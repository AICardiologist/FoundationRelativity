/-- Kovacic Case 3 degree bound for parameter n -/
def case3_degree (n : ℕ) : ℚ := -(n : ℚ) / 12

/-- Case 3, n=4: d = -1/3 < 0 -/
theorem case3_n4_negative : case3_degree 4 < 0 := by
