def gm_M11_num (t : ℚ) : ℚ := t
def gm_M12_num : ℚ := -1
def gm_M21_num (t : ℚ) : ℚ := t
def gm_M22_num (t : ℚ) : ℚ := -t

/-- Identity 5: Gauss-Manin trace vanishes.
