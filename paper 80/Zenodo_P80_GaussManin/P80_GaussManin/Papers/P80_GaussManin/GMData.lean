theorem gm_det_numerator (t : ℚ) :
    t * (-t) - (-1) * t = -t ^ 2 + t := by ring

-- ============================================================
-- §4. Griffiths–Coboundary Pole Reduction
-- ============================================================

/-- The defining polynomial of the Legendre family. -/
noncomputable def legendre_f (x t : ℚ) : ℚ := x * (x - 1) * (x - t)

/-- Identity 7: Expansion of the Legendre polynomial.
    x(x-1)(x-t) = x³ - (1+t)x² + tx. -/
theorem legendre_f_expand (x t : ℚ) :
    x * (x - 1) * (x - t) = x ^ 3 - (1 + t) * x ^ 2 + t * x := by ring

/-- The derivative ∂f/∂x. -/
noncomputable def legendre_df_dx (x t : ℚ) : ℚ := 3 * x ^ 2 - 2 * (1 + t) * x + t

/-- Identity 8: ∂f/∂x is the formal derivative of f w.r.t. x. -/
theorem legendre_df_dx_correct (x t : ℚ) :
    3 * x ^ 2 - 2 * (1 + t) * x + t =
    3 * x ^ 2 - 2 * x - 2 * t * x + t := by ring

/-- The derivative ∂f/∂t. -/
noncomputable def legendre_df_dt (x _t : ℚ) : ℚ := -x ^ 2 + x

/-- Identity 9: ∂f/∂t = x(1-x) = -x² + x. -/
theorem legendre_df_dt_correct (x : ℚ) :
    -x ^ 2 + x = x * (1 - x) := by ring

/-- Identity 10: Griffiths polynomial division (Step 1 of pole reduction).
    3(x²-x) = f'(x) + ((2t-1)x - t).

    This removes the exact component: f'(x)·dx/(2y³) = -d(1/y).
    But the remainder (2t-1)x - t is STILL in y³, not y.
    The coboundary identity (Identity 11) completes the reduction. -/
theorem griffiths_division (x t : ℚ) :
    3 * (x ^ 2 - x) =
    (3 * x ^ 2 - 2 * (1 + t) * x + t) + ((2 * t - 1) * x - t) := by ring

/-- Identity 11: THE GAUSS-MANIN COBOUNDARY IDENTITY (complete pole reduction).

    t(1-t)(x²-x) = (3x+t-2)·f(x) - (x²-x)·f'(x)

    This is the master identity for the Griffiths–coboundary reduction.
    Dividing by 2y³:
      t(1-t) · (x²-x)/(2y³) = (3x+t-2)/(2y) - [(x²-x)f'(x)]/(2y³)

    The first term: f(x)/y³ = 1/y, so (3x+t-2)f/(2y³) = (3x+t-2)/(2y)
      = [(t-2)/2]·ω₀ + (3/2)·ω₁

    The second term: by the coboundary formula d(h/y) = h'/y - hf'/(2y³),
    with h = x²-x, h' = 2x-1:
      (x²-x)f'/(2y³) = (2x-1)/y - d((x²-x)/y) = 2ω₁ - ω₀ + exact

    Combining: t(1-t)·∇_t(ω₀) = [(t-2)/2 + 1]ω₀ + [3/2 - 2]ω₁
      = (t/2)ω₀ - (1/2)ω₁

    Therefore: ∇_t(ω₀) = [1/(2(1-t))]ω₀ - [1/(2t(1-t))]ω₁  -/
theorem gm_coboundary_identity (x t : ℚ) :
    t * (1 - t) * (x ^ 2 - x) =
    (3 * x + t - 2) * (x ^ 3 - (1 + t) * x ^ 2 + t * x) -
    (x ^ 2 - x) * (3 * x ^ 2 - 2 * (1 + t) * x + t) := by ring

/-- Identity 12: Row 2 factorization.
    x³ - x² = f(x) + t(x²-x).

    Since f(x)/y³ = 1/y = ω₀:
      ∇_t(ω₁) = (x³-x²)/(2y³) = f/(2y³) + t·(x²-x)/(2y³)
               = (1/2)ω₀ + t·∇_t(ω₀)

    Substituting Row 1:
      ∇_t(ω₁) = (1/2)ω₀ + t·[1/(2(1-t))·ω₀ - 1/(2t(1-t))·ω₁]
               = [1/(2(1-t))]ω₀ - [1/(2(1-t))]ω₁  -/
theorem gm_row2_factorization (x t : ℚ) :
    x ^ 3 - x ^ 2 =
    (x ^ 3 - (1 + t) * x ^ 2 + t * x) + t * (x ^ 2 - x) := by ring

/-- Identity 13: Griffiths full reduction verification (alternate form).
    The inverse of the coboundary identity, confirming
    -3(x²-x) + f'(x) = -(2t-1)x + t. -/
theorem griffiths_full_reduction (x t : ℚ) :
    -3 * (x ^ 2 - x) + (3 * x ^ 2 - 2 * (1 + t) * x + t) =
    -(2 * t - 1) * x + t := by ring

