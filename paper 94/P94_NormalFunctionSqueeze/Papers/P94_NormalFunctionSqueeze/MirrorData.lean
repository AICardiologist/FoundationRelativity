-- The indicial exponents are {0, 1, 1, 2}.
-- The repeated exponent 1 indicates a rank-1 logarithmic singularity.
-- Physically: the vanishing 3-cycle S³ that becomes the massless D-brane.

-- Indicial polynomial: ρ(ρ-1)²(ρ-2) = ρ⁴ - 4ρ³ + 5ρ² - 2ρ
theorem conifold_indicial_poly (r : ℤ) :
    r * (r - 1) * (r - 1) * (r - 2) = r ^ 4 - 4 * r ^ 3 + 5 * r ^ 2 - 2 * r := by ring

-- Roots: 0, 1 (double), 2
