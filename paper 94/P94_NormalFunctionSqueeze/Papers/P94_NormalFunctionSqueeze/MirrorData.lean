-- §1. Picard-Fuchs coefficients in standard derivative form
-- L = P₄(z)D⁴ + P₃(z)D³ + P₂(z)D² + P₁(z)D + P₀(z)
-- Computed via Stirling expansion of the theta-form operator.

/-- Coefficient of D⁰ in the standard-form PF operator -/
noncomputable def pf_P0 (z : ℚ) : ℚ := -120 * z

/-- Coefficient of D¹ in the standard-form PF operator -/
noncomputable def pf_P1 (z : ℚ) : ℚ := -15000 * z ^ 2 + z

/-- Coefficient of D² in the standard-form PF operator -/
noncomputable def pf_P2 (z : ℚ) : ℚ := -45000 * z ^ 3 + 7 * z ^ 2

/-- Coefficient of D³ in the standard-form PF operator -/
