/-- Coefficient of D⁴ (leading coefficient) in the standard-form PF operator -/
noncomputable def pf_P4 (z : ℚ) : ℚ := -3125 * z ^ 5 + z ^ 4

-- §2. RHS product expansion identity
-- (5θ+1)(5θ+2)(5θ+3)(5θ+4) = 625θ⁴ + 1250θ³ + 875θ² + 250θ + 24
-- Verified by expanding the product of four linear factors over ℤ[θ]

theorem rhs_product_expand (t : ℤ) :
    (5 * t + 1) * (5 * t + 2) * (5 * t + 3) * (5 * t + 4) =
    625 * t ^ 4 + 1250 * t ^ 3 + 875 * t ^ 2 + 250 * t + 24 := by ring

