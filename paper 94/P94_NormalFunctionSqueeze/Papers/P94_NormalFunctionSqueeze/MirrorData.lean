-- §5. Weyl algebra expansion verification
-- For each D^k, the sum of Stirling contributions from all θ^n terms equals P_k(z).
--
-- L_θ = θ⁴ - 5z·(5θ+1)(5θ+2)(5θ+3)(5θ+4)
--     = (1-3125z)·θ⁴ - 6250z·θ³ - 4375z·θ² - 1250z·θ - 120z
--
-- θ^n = Σ_k S(n,k) z^k D^k, so each (c_n · θ^n) contributes c_n · S(n,k) · z^k to D^k.
-- We verify the total at each D^k matches the standard-form coefficient P_k(z).

-- D⁴: (1-3125z)·S(4,4)·z⁴ = (1-3125z)·1·z⁴
theorem weyl_D4_coeff (z : ℚ) :
    (1 - 3125 * z) * 1 * z ^ 4 = pf_P4 z := by
  unfold pf_P4; ring

-- D³: (1-3125z)·S(4,3)·z³ + (-6250z)·S(3,3)·z³
theorem weyl_D3_coeff (z : ℚ) :
    (1 - 3125 * z) * 6 * z ^ 3 + (-6250 * z) * 1 * z ^ 3 = pf_P3 z := by
  unfold pf_P3; ring

-- D²: (1-3125z)·S(4,2)·z² + (-6250z)·S(3,2)·z² + (-4375z)·S(2,2)·z²
theorem weyl_D2_coeff (z : ℚ) :
    (1 - 3125 * z) * 7 * z ^ 2 + (-6250 * z) * 3 * z ^ 2 +
    (-4375 * z) * 1 * z ^ 2 = pf_P2 z := by
  unfold pf_P2; ring

-- D¹: contributions from θ⁴(S(4,1)=1), θ³(S(3,1)=1), θ²(S(2,1)=1), θ¹(S(1,1)=1)
theorem weyl_D1_coeff (z : ℚ) :
    (1 - 3125 * z) * 1 * z + (-6250 * z) * 1 * z +
    (-4375 * z) * 1 * z + (-1250 * z) * 1 * z = pf_P1 z := by
  unfold pf_P1; ring

-- D⁰: only the constant term -120z contributes (θ⁰ = identity)
theorem weyl_D0_coeff (z : ℚ) :
    -120 * z = pf_P0 z := by
  unfold pf_P0; ring

