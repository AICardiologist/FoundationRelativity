-- ═══ Exponent Differences & Non-Resonance (BISH) ═══
-- Resonance = difference ∈ ℤ. For ℚ-params: decidable. For ℂ-params: LPO.
def diff_zero : ℚ := 1/3
def diff_one : ℚ := 1/12
def diff_inf : ℚ := 1/12

theorem diff_zero_not_int : ∀ n : ℤ, diff_zero ≠ (n : ℚ) := by
  intro n; simp only [diff_zero]; intro h
  have : (1 : ℚ) / 3 = ↑n := h
  have : (3 : ℚ) * (↑n) = 1 := by linarith
  have : (3 : ℤ) * n = 1 := by exact_mod_cast this
  omega

theorem diff_one_not_int : ∀ n : ℤ, diff_one ≠ (n : ℚ) := by
  intro n; simp only [diff_one]; intro h
  have : (1 : ℚ) / 12 = ↑n := h
  have : (12 : ℚ) * (↑n) = 1 := by linarith
  have : (12 : ℤ) * n = 1 := by exact_mod_cast this
  omega

theorem diff_inf_not_int : ∀ n : ℤ, diff_inf ≠ (n : ℚ) := by
  intro n; simp only [diff_inf]; intro h
  have : (1 : ℚ) / 12 = ↑n := h
  have : (12 : ℚ) * (↑n) = 1 := by linarith
  have : (12 : ℤ) * n = 1 := by exact_mod_cast this
  omega

-- ═══ Fuchs Relation (BISH) ═══
-- Sum of all exponents = n-1 where n = number of singular points minus 1
-- For ℙ¹ with 3 singularities: sum = 3·1 - 2 = 1
theorem fuchs_relation :
    exp_zero_1 + exp_zero_2 + exp_one_1 + exp_one_2
    + exp_inf_1 + exp_inf_2 = 1 := by
  norm_num [exp_zero_1, exp_zero_2, exp_one_1, exp_one_2, exp_inf_1, exp_inf_2]

